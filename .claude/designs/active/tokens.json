{
  "colors": {
    "fromCssVariables": {
      "--primary": "#171717",
      "--secondary": "#4d4d4d",
      "--accent": "#006bff",
      "--background-100": "#ffffff",
      "--background-200": "#fafafa",
      "--gray-400": "#eaeaea",
      "--gray-700": "#8f8f8f",
      "--gray-900": "#4d4d4d",
      "--gray-1000": "#171717",
      "--gray-alpha-400": "#00000014",
      "--blue-700": "#006bff",
      "--red-800": "#ea001d"
    },
    "fromColorProps": ["#171717", "#4d4d4d", "#006bff", "#ffffff", "#fafafa", "#eaeaea", "#8f8f8f", "#ea001d"]
  },
  "typography": {
    "fontFamilies": ["Geist Sans", "Geist Mono", "-apple-system", "sans-serif"],
    "baseFontSizePx": 16,
    "headingSizesPx": { "h1": 72, "h2": 48, "h3": 32, "h4": 24, "h5": 20, "h6": 16 }
  },
  "spacingAndRadius": {
    "spacingValuesPx": [4, 8, 12, 16, 24, 32, 40, 64, 96],
    "borderRadiiPx": [6, 12, 16, 9999]
  },
  "shadows": [
    "0 2px 2px rgba(0,0,0,0.04)",
    "0 1px 1px rgba(0,0,0,0.02), 0 4px 8px -4px rgba(0,0,0,0.04), 0 16px 24px -8px rgba(0,0,0,0.06)",
    "0 1px 1px rgba(0,0,0,0.02), 0 8px 16px -4px rgba(0,0,0,0.04), 0 24px 32px -8px rgba(0,0,0,0.06)"
  ],
  "components": {
    "buttons": [".button-primary { background:#171717; color:#ffffff; border-radius:6px; height:40px; padding:0 10px; font:500 14px Geist Sans; }"],
    "cards": [".card { background:#ffffff; border:1px solid #00000014; border-radius:16px; padding:24px; box-shadow:0 2px 2px rgba(0,0,0,0.04); }"],
    "forms": [".input { background:#ffffff; border:1px solid #00000014; border-radius:6px; height:40px; padding:0 12px; }"]
  },
  "layoutNotes": {
    "usesTailwind": false,
    "usesCssFrameworkGuess": "Geist"
  }
}
