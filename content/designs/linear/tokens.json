{
  "colors": {
    "fromCssVariables": {
      "--bg": "#08090A",
      "--panel": "#15171A",
      "--border": "#23262B",
      "--indigo": "#5E6AD2",
      "--text": "#F7F8F8",
      "--muted": "#8A8F98"
    },
    "fromColorProps": ["#08090A", "#15171A", "#23262B", "#5E6AD2", "#F7F8F8", "#8A8F98"]
  },
  "typography": {
    "fontFamilies": ["Inter Variable", "Inter", "-apple-system", "sans-serif"],
    "baseFontSizePx": 16,
    "headingSizesPx": { "h1": 56, "h2": 36, "h3": 20, "h4": 16, "h5": 14, "h6": 12 }
  },
  "spacingAndRadius": {
    "spacingValuesPx": [4, 8, 12, 16, 24, 32, 48, 64, 80],
    "borderRadiiPx": [8, 12, 16]
  },
  "shadows": [
    "0 8px 40px rgba(0,0,0,0.5)",
    "0 0 0 1px rgba(94,106,210,0.4)"
  ],
  "components": {
    "buttons": [".btn-primary { background:#5E6AD2; color:#fff; border-radius:8px; padding:9px 16px; font-weight:500; }"],
    "cards": [".card { background:#15171A; border:1px solid #23262B; border-radius:12px; padding:24px; }"],
    "forms": [".input { background:#15171A; border:1px solid #23262B; border-radius:8px; color:#F7F8F8; }"]
  },
  "layoutNotes": {
    "usesTailwind": false,
    "usesCssFrameworkGuess": null
  }
}
