{
  "colors": {
    "fromCssVariables": {
      "--navy": "#0A2540",
      "--purple": "#635BFF",
      "--slate": "#425466",
      "--muted": "#697386",
      "--bg-soft": "#F6F9FC",
      "--border": "#E3E8EE",
      "--danger": "#DF1B41"
    },
    "fromColorProps": ["#0A2540", "#635BFF", "#425466", "#697386", "#F6F9FC", "#FFFFFF", "#E3E8EE", "#DF1B41"]
  },
  "typography": {
    "fontFamilies": ["Söhne", "-apple-system", "Helvetica Neue", "Arial", "sans-serif"],
    "baseFontSizePx": 16,
    "headingSizesPx": { "h1": 52, "h2": 32, "h3": 22, "h4": 18, "h5": 16, "h6": 14 }
  },
  "spacingAndRadius": {
    "spacingValuesPx": [4, 8, 12, 16, 24, 32, 48, 64, 96],
    "borderRadiiPx": [8, 16, 9999]
  },
  "shadows": [
    "0 2px 5px rgba(0,0,0,0.08)",
    "0 15px 35px rgba(0,0,0,0.1)"
  ],
  "components": {
    "buttons": [".Button--primary { background:#635BFF; color:#fff; border-radius:8px; padding:10px 18px; font-weight:600; }"],
    "cards": [".Card { border-radius:16px; box-shadow:0 15px 35px rgba(0,0,0,0.1); padding:32px; }"],
    "forms": [".Input { border:1px solid #E3E8EE; border-radius:8px; padding:10px 12px; }"]
  },
  "layoutNotes": {
    "usesTailwind": false,
    "usesCssFrameworkGuess": null
  }
}
