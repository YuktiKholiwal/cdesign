{
  "colors": {
    "fromCssVariables": {
      "--black": "#000000",
      "--white": "#FFFFFF",
      "--dark": "#0A0A0A",
      "--gray": "#666666",
      "--border": "#EAEAEA",
      "--border-dark": "#333333",
      "--danger": "#EE0000"
    },
    "fromColorProps": ["#000000", "#FFFFFF", "#0A0A0A", "#666666", "#EAEAEA", "#333333", "#EE0000"]
  },
  "typography": {
    "fontFamilies": ["Geist", "-apple-system", "SF Pro", "Segoe UI", "sans-serif"],
    "baseFontSizePx": 16,
    "headingSizesPx": { "h1": 64, "h2": 40, "h3": 24, "h4": 18, "h5": 16, "h6": 14 }
  },
  "spacingAndRadius": {
    "spacingValuesPx": [4, 8, 16, 24, 32, 48, 64, 96, 128],
    "borderRadiiPx": [6, 8, 12]
  },
  "shadows": [
    "0 4px 12px rgba(0,0,0,0.08)"
  ],
  "components": {
    "buttons": [".btn-primary { background:#000; color:#fff; border-radius:8px; padding:10px 16px; font-weight:500; }"],
    "cards": [".card { border:1px solid #EAEAEA; border-radius:12px; padding:24px; }"],
    "forms": [".input { border:1px solid #EAEAEA; border-radius:8px; padding:10px 12px; }"]
  },
  "layoutNotes": {
    "usesTailwind": false,
    "usesCssFrameworkGuess": null
  }
}
